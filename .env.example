# ── Vision OCR providers ──────────────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2-vision:11b

# auto = try Groq first, fall back to Ollama
# groq  = force Groq
# ollama = force Ollama
DEFAULT_PROVIDER=auto

# ── File size limit ───────────────────────────────────────────────────────────
MAX_FILE_SIZE_MB=15

# ── API security ──────────────────────────────────────────────────────────────
# Set a secret key here. Every request must include: X-API-Key: <your-key>
# Leave blank to disable API key enforcement (dev/local only).
API_KEY=

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins.
# Example: http://localhost:3000,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# ── Sandbox.co.in official verification (optional) ───────────────────────────
SANDBOX_BASE_URL=https://api.sandbox.co.in
SANDBOX_API_KEY=
SANDBOX_AUTH_TOKEN=
